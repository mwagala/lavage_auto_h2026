APP_ENV=development
TESTING=False
DEBUG=True
FLASK_DEBUG=True

DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=lavage_auto
DB_PORT=5432
DB_CONNECT_TIMEOUT=5
HEALTH_CHECK_TIMEOUT=0.25
HEALTH_CHECK_CELERY_WORKER=False

SECRET_KEY=change_me_secret_key_minimum_32_characters
JWT_SECRET_KEY=change_me_jwt_secret_key_minimum_32_characters
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=120
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
SECURITY_HEADERS_ENABLED=True
RATE_LIMITING_ENABLED=True
RATE_LIMITING_BACKEND=redis
RATE_LIMITING_REDIS_TIMEOUT_SECONDS=0.25
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_REGISTER_RATE_LIMIT_ATTEMPTS=5
AUTH_REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
OUTBOX_CONSUMER_INTERVAL_SECONDS=60
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RETRY_BACKOFF_SECONDS=60
OUTBOX_MAX_RETRY_DELAY_SECONDS=3600
OUTBOX_STALE_PROCESSING_SECONDS=900
OUTBOX_STALE_RESET_LIMIT=100
LOG_LEVEL=INFO
CELERY_TASK_ALWAYS_EAGER=False
